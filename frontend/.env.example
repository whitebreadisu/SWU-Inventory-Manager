# Firebase Auth Emulator (P5 Stage 3 local dev). Set to "true" to point the
# frontend's Firebase SDK at the local Auth Emulator (see docker-compose.yml's
# firebase-emulator service). Leave unset/"false" for a real deployment.
VITE_USE_AUTH_EMULATOR=true

# Firebase project config. For local dev with the emulator, the "demo-swu"
# values below work as-is -- the emulator doesn't validate them. For the real
# deployment, these come from terraform/environments/prod's
# google_firebase_web_app_config (firebase.tf/outputs.tf) and are injected by
# ci.yml's frontend-deploy job at build time -- no .env needed in CI.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-swu.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-swu
